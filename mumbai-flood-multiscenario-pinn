def slugify(text):
    return re.sub(r"[^a-zA-Z0-9]+", "_", text.strip()).strip("_").lower()

def rot_gauss_torch(x, y, xc, yc, sx, sy, theta_rad):
    ct = math.cos(theta_rad)
    st = math.sin(theta_rad)
    xr =  ct * (x - xc) + st * (y - yc)
    yr = -st * (x - xc) + ct * (y - yc)
    return torch.exp(-0.5 * ((xr / sx) ** 2 + (yr / sy) ** 2))

# ============================================================
# RAINFALL CASE BUILDER
# ============================================================
def build_rainfall_fn(case):
    peak_mmhr = float(case.get("peak_mmhr", 140.0))
    shield_amp = float(case.get("shield_amp", 1.0))
    band_amp = float(case.get("band_amp", 0.7))
    cell_amp = float(case.get("cell_amp", 0.5))
    coast_amp = float(case.get("coast_amp", 0.3))
    corridor_amp = float(case.get("corridor_amp", 0.25))
    shift_x = float(case.get("shift_x", 0.0))
    shift_y = float(case.get("shift_y", 0.0))
    temporal_shift = float(case.get("temporal_shift", 0.0))
    duration_scale = float(case.get("duration_scale", 1.0))
    band_rotation = float(case.get("band_rotation", 0.0))

    def rainfall(x, y, t):
        """
        Rainfall in m/s.
        Inputs: normalized x, y, t in [0,1]
        """
        tt = torch.clamp(t + temporal_shift, 0.0, 1.0)

        # Broad temporal envelope
        s1 = 0.11 * duration_scale
        s2 = 0.14 * duration_scale
        s3 = 0.12 * duration_scale

        p1 = torch.exp(-0.5 * ((tt - 0.22) / s1) ** 2)
        p2 = torch.exp(-0.5 * ((tt - 0.48) / s2) ** 2)
        p3 = torch.exp(-0.5 * ((tt - 0.74) / s3) ** 2)
        temporal = 0.55 * p1 + 1.00 * p2 + 0.75 * p3
        temporal = temporal * (0.92 + 0.08 * torch.sin(2.0 * np.pi * (2.5 * tt + 0.10)))

        # Broad mesoscale shields
        shield1 = rot_gauss_torch(
            x, y,
            0.38 + 0.10 * tt + shift_x,
            0.72 - 0.06 * tt + shift_y,
            0.28, 0.16, -0.55 + band_rotation
        )
        shield2 = rot_gauss_torch(
            x, y,
            0.58 - 0.06 * tt + shift_x,
            0.50 + shift_y,
            0.24, 0.18, -0.35 + band_rotation
        )
        mesoscale = 0.75 * shield1 + 0.55 * shield2

        # Elongated rainbands
        band1 = rot_gauss_torch(
            x, y,
            0.22 + 0.18 * tt + shift_x,
            0.76 - 0.10 * tt + shift_y,
            0.34, 0.055, -0.85 + band_rotation
        )
        band2 = rot_gauss_torch(
            x, y,
            0.30 + 0.16 * tt + shift_x,
            0.58 - 0.06 * tt + shift_y,
            0.30, 0.060, -0.80 + band_rotation
        )
        band3 = rot_gauss_torch(
            x, y,
            0.42 + 0.10 * tt + shift_x,
            0.42 + shift_y,
            0.26, 0.050, -0.72 + band_rotation
        )
        bands = 0.80 * band1 + 0.65 * band2 + 0.45 * band3

        # Embedded convective cells
        c1 = rot_gauss_torch(x, y, 0.18 + 0.22 * tt + shift_x, 0.82 - 0.14 * tt + shift_y, 0.060, 0.045, -0.30)
        c2 = rot_gauss_torch(x, y, 0.32 + 0.18 * tt + shift_x, 0.68 - 0.10 * tt + shift_y, 0.055, 0.040,  0.10)
        c3 = rot_gauss_torch(x, y, 0.48 + 0.10 * tt + shift_x, 0.56 - 0.05 * tt + shift_y, 0.050, 0.038, -0.20)
        c4 = rot_gauss_torch(x, y, 0.62 - 0.06 * tt + shift_x, 0.44 + 0.02 * tt + shift_y, 0.052, 0.040,  0.35)
        c5 = rot_gauss_torch(x, y, 0.72 - 0.10 * tt + shift_x, 0.30 + 0.05 * tt + shift_y, 0.060, 0.042, -0.15)
        cells = 1.00 * c1 + 0.95 * c2 + 0.85 * c3 + 0.75 * c4 + 0.65 * c5

        # Coastal + corridor enhancement
        coast = torch.exp(-((x - (0.18 + 0.4 * shift_x)) / 0.22) ** 2) * (0.65 + 0.35 * y)
        mithi_corridor = torch.exp(-((x - (0.50 + shift_x)) / 0.10) ** 2) * torch.exp(-((y - (0.42 + shift_y)) / 0.13) ** 2)
        kurla_dharavi = torch.exp(-((x - (0.46 + shift_x)) / 0.08) ** 2) * torch.exp(-((y - (0.38 + shift_y)) / 0.08) ** 2)
        thane_creek = torch.exp(-((x - (0.85 + shift_x)) / 0.10) ** 2) * torch.exp(-((y - (0.48 + shift_y)) / 0.12) ** 2)
        corridor = 0.55 * mithi_corridor + 0.25 * kurla_dharavi + 0.20 * thane_creek

        # Gentle large-scale gradient
        gradient = 0.78 + 0.18 * y + 0.10 * (1.0 - x)

        spatial = (
            0.20
            + shield_amp * 0.75 * mesoscale
            + band_amp * 0.65 * bands
            + cell_amp * 0.55 * cells
            + coast_amp * coast
            + corridor_amp * corridor
        ) * gradient

        rain_ms = (peak_mmhr / 1000.0 / 3600.0) * temporal * spatial
        return rain_ms

    return rainfall

