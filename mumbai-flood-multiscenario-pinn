@torch.no_grad()
def predict_field(model, t_norm, res):
    xi = np.linspace(0, 1, res)
    yi = np.linspace(0, 1, res)
    xx, yy = np.meshgrid(xi, yi)

    x = torch.tensor(xx.ravel(), dtype=torch.float32, device=DEVICE)
    y = torch.tensor(yy.ravel(), dtype=torch.float32, device=DEVICE)
    t = torch.full_like(x, float(t_norm))

    h, u, v = model(x, y, t)
    H = h.cpu().numpy().reshape(res, res)
    U = u.cpu().numpy().reshape(res, res)
    V = v.cpu().numpy().reshape(res, res)
    return xi, yi, H, U, V

@torch.no_grad()
def rainfall_grid(rainfall_fn, t_norm, res):
    xi = np.linspace(0.0, 1.0, res)
    yi = np.linspace(0.0, 1.0, res)
    xx, yy = np.meshgrid(xi, yi)

    x = torch.tensor(xx.ravel(), dtype=torch.float32, device=DEVICE)
    y = torch.tensor(yy.ravel(), dtype=torch.float32, device=DEVICE)
    t = torch.full_like(x, float(t_norm))

    r_ms = rainfall_fn(x, y, t)
    R_mmhr = r_ms.cpu().numpy().reshape(res, res) * 1000.0 * 3600.0
    return xi, yi, R_mmhr

# ============================================================
# PLOTTING
# ============================================================
def plot_loss(history, save_path, title):
    plt.figure(figsize=(9, 4))
    for k in ["total", "pde", "ic", "bc", "data"]:
        plt.semilogy(history["epoch"], history[k], label=k)
    plt.xlabel("Epoch")
    plt.ylabel("Loss")
    plt.title(title)
    plt.grid(True, alpha=0.3)
    plt.legend()
    plt.tight_layout()
    plt.savefig(save_path, dpi=150)
    plt.close()
    print(f"[SAVED] {save_path}")

def plot_peak_depth_map(peak_H, outline, save_path, title, mask=None):
    H = peak_H.copy()
    if mask is not None:
        H[~mask] = np.nan

    vmax = max(0.5, float(np.nanpercentile(H, 99))) if np.isfinite(H).any() else 0.5

    plt.figure(figsize=(7, 6))
    ax = plt.gca()
    im = ax.imshow(H[::-1], extent=[0, 1, 0, 1], cmap="turbo", vmin=0, vmax=vmax, aspect="auto")
    draw_outline(ax, outline)
    ax.set_title(title)
    ax.set_xlabel("Normalized Easting")
    ax.set_ylabel("Normalized Northing")
    plt.colorbar(im, ax=ax, label="Peak inundation depth (m)")
    plt.tight_layout()
    plt.savefig(save_path, dpi=160)
    plt.close()
    print(f"[SAVED] {save_path}")

def plot_summary_bar(summary_rows, save_path):
    names = [r["case"] for r in summary_rows]
    peak_rain = [r["peak_rain_mmhr"] for r in summary_rows]
    peak_depth = [r["peak_depth_m"] for r in summary_rows]

    x = np.arange(len(names))
    w = 0.38

    fig, ax1 = plt.subplots(figsize=(11, 5))
    ax1.bar(x - w/2, peak_rain, width=w, label="Peak rainfall (mm/hr)")
    ax1.set_ylabel("Peak rainfall (mm/hr)")
    ax1.set_xticks(x)
    ax1.set_xticklabels(names, rotation=20, ha="right")

    ax2 = ax1.twinx()
    ax2.bar(x + w/2, peak_depth, width=w, label="Peak depth (m)")
    ax2.set_ylabel("Peak depth (m)")

    ax1.set_title("Rainfall-case comparison")
    ax1.grid(True, axis="y", alpha=0.25)

    h1, l1 = ax1.get_legend_handles_labels()
    h2, l2 = ax2.get_legend_handles_labels()
    ax1.legend(h1 + h2, l1 + l2, loc="upper left")

    plt.tight_layout()
    plt.savefig(save_path, dpi=160)
    plt.close()
    print(f"[SAVED] {save_path}")

# ============================================================
# GIF MAKER
# ============================================================
def make_side_by_side_gif(
    model,
    dem,
    outline,
    rainfall_fn,
    out_path,
    grid_res=GRID_RES,
    gif_frames=GIF_FRAMES,
    gif_fps=GIF_FPS,
    mask_outside=True,
    add_velocity=False,
    quiver_step=12,
):
    model.eval()

    out_dir = os.path.dirname(out_path)
    if out_dir:
        os.makedirs(out_dir, exist_ok=True)

    print(f"[GIF] Building {gif_frames} frames...")
    tvals = np.linspace(0.0, 1.0, gif_frames)

    mask = None
    if outline is not None and mask_outside:
        mask = outline_mask(outline, dem, grid_res)
        print(f"[GIF] Boundary mask active: {100.0 * mask.mean():.1f}% inside domain")

    rain_fields = []
    depth_fields = []
    u_fields = []
    v_fields = []

    rain_max = 20.0
    depth_max = 0.5

    # Precompute fields to stabilize color scale
    for tn in tvals:
        _, _, R = rainfall_grid(rainfall_fn, tn, grid_res)
        _, _, H, U, V = predict_field(model, tn, grid_res)

        if mask is not None:
            R = R.copy()
            H = H.copy()
            U = U.copy()
            V = V.copy()
            R[~mask] = np.nan
            H[~mask] = np.nan
            U[~mask] = np.nan
            V[~mask] = np.nan

        rain_fields.append(R)
        depth_fields.append(H)
        u_fields.append(U)
        v_fields.append(V)

        if np.isfinite(R).any():
            rain_max = max(rain_max, float(np.nanpercentile(R, 99)))
        if np.isfinite(H).any():
            depth_max = max(depth_max, float(np.nanpercentile(H, 99)))

    print(f"[GIF] Rainfall scale: 0 to {rain_max:.1f} mm/hr")
    print(f"[GIF] Depth scale: 0 to {depth_max:.2f} m")

    # Peak depth map
    depth_stack = np.stack([np.where(np.isfinite(H), H, -np.inf) for H in depth_fields], axis=0)
    peak_H = np.max(depth_stack, axis=0)
    peak_H[peak_H == -np.inf] = np.nan

    frames = []
    xi = np.linspace(0.0, 1.0, grid_res)
    yi = np.linspace(0.0, 1.0, grid_res)

    for i, tn in enumerate(tvals):
        R = rain_fields[i]
        H = depth_fields[i]
        U = u_fields[i]
        V = v_fields[i]

        sim_minutes = (tn * T_END_SECONDS) / 60.0

        fig, axes = plt.subplots(1, 2, figsize=(14, 6), dpi=110)
        ax1, ax2 = axes

        # Left: rainfall
        im1 = ax1.imshow(
            R[::-1],
            extent=[0, 1, 0, 1],
            cmap="Blues",
            vmin=0.0,
            vmax=rain_max,
            aspect="auto",
        )
        draw_outline(ax1, outline)
        ax1.set_title(f"Spatial Rainfall\nTime = {sim_minutes:.1f} min")
        ax1.set_xlabel("Normalized Easting")
        ax1.set_ylabel("Normalized Northing")
        cb1 = fig.colorbar(im1, ax=ax1, fraction=0.046, pad=0.04)
        cb1.set_label("Rainfall (mm/hr)")

        # Right: inundation
        im2 = ax2.imshow(
            H[::-1],
            extent=[0, 1, 0, 1],
            cmap="turbo",
            vmin=0.0,
            vmax=depth_max,
            aspect="auto",
        )
        draw_outline(ax2, outline)

        if add_velocity:
            xxq, yyq = np.meshgrid(xi[::quiver_step], yi[::quiver_step])
            Uq = U[::quiver_step, ::quiver_step]
            Vq = V[::quiver_step, ::quiver_step]
            Hq = H[::quiver_step, ::quiver_step]
            wet = np.isfinite(Hq) & (Hq > 0.05)
            if np.any(wet):
                ax2.quiver(xxq[wet], yyq[wet], Uq[wet], Vq[wet], color="k", scale=35, width=0.002)

        ax2.set_title(f"Inundation Depth\nTime = {sim_minutes:.1f} min")
        ax2.set_xlabel("Normalized Easting")
        ax2.set_ylabel("Normalized Northing")
        cb2 = fig.colorbar(im2, ax=ax2, fraction=0.046, pad=0.04)
        cb2.set_label("Depth (m)")

        fig.suptitle(f"Mumbai Flood PINN | Frame {i+1}/{gif_frames}", fontsize=14, fontweight="bold")
        plt.tight_layout()

        buf = io.BytesIO()
        plt.savefig(buf, format="png", bbox_inches="tight")
        plt.close(fig)
        buf.seek(0)
        frames.append(Image.open(buf).convert("P", palette=Image.ADAPTIVE).copy())

    frames[0].save(
        out_path,
        save_all=True,
        append_images=frames[1:],
        duration=int(1000 / gif_fps),
        loop=0,
        optimize=True,
    )

    print(f"[SAVED] {out_path}")
    return {
        "mask": mask,
        "peak_H": peak_H,
        "peak_rain_mmhr": rain_max,
        "peak_depth_m": depth_max,
    }

# ============================================================
# RUN ONE CASE
# ============================================================
def run_case(case, dem, outline):
    case_name = case["name"]
    slug = slugify(case_name)
    case_dir = os.path.join(OUT_DIR, slug)
    os.makedirs(case_dir, exist_ok=True)

    print("\n" + "=" * 70)
    print(f"[CASE] {case_name}")
    print("=" * 70)

    rainfall_fn = build_rainfall_fn(case)

    model = FloodPINN(hidden=128, layers=5, fourier=24).to(DEVICE)

    history = train_model(model, dem, rainfall_fn, epochs=EPOCHS_PER_CASE)

    model_path = os.path.join(case_dir, f"{slug}_model.pt")
    torch.save(model.state_dict(), model_path)
    print(f"[SAVED] {model_path}")

    loss_path = os.path.join(case_dir, f"{slug}_loss.png")
    plot_loss(history, loss_path, f"{case_name} - training loss")

    gif_path = os.path.join(case_dir, f"{slug}_rainfall_vs_inundation.gif")
    gif_info = make_side_by_side_gif(
        model=model,
        dem=dem,
        outline=outline,
        rainfall_fn=rainfall_fn,
        out_path=gif_path,
        grid_res=GRID_RES,
        gif_frames=GIF_FRAMES,
        gif_fps=GIF_FPS,
        mask_outside=True,
        add_velocity=False,
    )

    peak_map_path = os.path.join(case_dir, f"{slug}_peak_depth_map.png")
    plot_peak_depth_map(
        gif_info["peak_H"],
        outline,
        peak_map_path,
        f"{case_name} - peak inundation depth",
        mask=gif_info["mask"],
    )

    summary = {
        "case": case_name,
        "case_dir": case_dir,
        "model_path": model_path,
        "loss_plot": loss_path,
        "gif_path": gif_path,
        "peak_map_path": peak_map_path,
        "peak_rain_mmhr": gif_info["peak_rain_mmhr"],
        "peak_depth_m": gif_info["peak_depth_m"],
    }

    # Free memory
    del model
    gc.collect()
    if torch.cuda.is_available():
        torch.cuda.empty_cache()

    return summary

