def load_dem(path):
    import rasterio

    with rasterio.open(path) as src:
        arr = src.read(1).astype(np.float32)
        bounds = src.bounds
        nodata = src.nodata
        h, w = arr.shape

    if nodata is not None:
        arr[arr == nodata] = np.nan

    arr = np.nan_to_num(arr, nan=0.0)
    arr[arr < -100] = 0.0

    # Flip so y=0 is south, y=1 is north
    arr_flip = np.flipud(arr)

    lon_min, lon_max = float(bounds.left), float(bounds.right)
    lat_min, lat_max = float(bounds.bottom), float(bounds.top)

    mid_lat = 0.5 * (lat_min + lat_max)
    x_len = (lon_max - lon_min) * 111000.0 * np.cos(np.deg2rad(mid_lat))
    y_len = (lat_max - lat_min) * 111000.0

    xg = np.linspace(0.0, 1.0, w)
    yg = np.linspace(0.0, 1.0, h)

    elev_interp = RegularGridInterpolator(
        (yg, xg), arr_flip, bounds_error=False, fill_value=0.0
    )

    dzdy, dzdx = np.gradient(arr_flip, 1.0 / (h - 1), 1.0 / (w - 1))
    sx = dzdx / x_len
    sy = dzdy / y_len

    sx_interp = RegularGridInterpolator((yg, xg), sx, bounds_error=False, fill_value=0.0)
    sy_interp = RegularGridInterpolator((yg, xg), sy, bounds_error=False, fill_value=0.0)

    dem = {
        "arr": arr_flip,
        "h": h,
        "w": w,
        "lon_min": lon_min,
        "lon_max": lon_max,
        "lat_min": lat_min,
        "lat_max": lat_max,
        "x_len": x_len,
        "y_len": y_len,
        "elev_interp": elev_interp,
        "sx_interp": sx_interp,
        "sy_interp": sy_interp,
    }

    print(f"[DEM] Size: {w} x {h}")
    print(f"[DEM] Elevation range: {arr.min():.2f} to {arr.max():.2f} m")
    print(f"[DOMAIN] X length: {x_len/1000:.2f} km | Y length: {y_len/1000:.2f} km")
    return dem

def interp_torch(interp_fn, x, y):
    x_np = x.detach().cpu().numpy().ravel()
    y_np = y.detach().cpu().numpy().ravel()
    pts = np.stack([y_np, x_np], axis=-1)
    z = interp_fn(pts).astype(np.float32)
    return torch.tensor(z.reshape(x.shape), dtype=torch.float32, device=x.device)

