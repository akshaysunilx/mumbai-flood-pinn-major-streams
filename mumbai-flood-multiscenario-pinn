def sample_uniform(n):
    return (
        torch.rand(n, device=DEVICE),
        torch.rand(n, device=DEVICE),
        torch.rand(n, device=DEVICE),
    )

def sample_ic(n):
    return (
        torch.rand(n, device=DEVICE),
        torch.rand(n, device=DEVICE),
        torch.zeros(n, device=DEVICE),
    )

def sample_bc(n):
    t = torch.rand(n, device=DEVICE)
    return {
        "west":  (torch.zeros(n, device=DEVICE), torch.rand(n, device=DEVICE), t.clone()),
        "east":  (torch.ones(n, device=DEVICE),  torch.rand(n, device=DEVICE), t.clone()),
        "south": (torch.rand(n, device=DEVICE),  torch.zeros(n, device=DEVICE), t.clone()),
        "north": (torch.rand(n, device=DEVICE),  torch.ones(n, device=DEVICE),  t.clone()),
    }

def sample_obs(n, rainfall_fn):
    zones = [
        (0.43, 0.38, 0.92),  # Dharavi
        (0.55, 0.45, 0.88),  # Kurla
        (0.12, 0.06, 0.85),  # Colaba
        (0.88, 0.48, 0.80),  # Thane Creek
        (0.30, 0.58, 0.62),  # Andheri side
        (0.65, 0.56, 0.58),  # Powai side
    ]

    xs, ys, ts, hs = [], [], [], []
    per = max(1, n // len(zones))

    for zx, zy, risk in zones:
        t = torch.rand(per, device=DEVICE)
        x = torch.normal(zx, 0.012, (per,), device=DEVICE).clamp(0, 1)
        y = torch.normal(zy, 0.012, (per,), device=DEVICE).clamp(0, 1)

        rain_mmhr = rainfall_fn(x, y, t) * 1000.0 * 3600.0
        h = 0.02 + 0.10 * risk + 0.0045 * risk * rain_mmhr
        h = torch.clamp(h, 0.02, 2.5)

        xs.append(x)
        ys.append(y)
        ts.append(t)
        hs.append(h)

    return torch.cat(xs), torch.cat(ys), torch.cat(ts), torch.cat(hs)

# ============================================================
# PHYSICS
# ============================================================
def grad(out, inp):
    return torch.autograd.grad(
        out, inp,
        grad_outputs=torch.ones_like(out),
        create_graph=True,
        retain_graph=True
    )[0]

def physics_residual(model, dem, rainfall_fn, x, y, t):
    x = x.clone().detach().requires_grad_(True)
    y = y.clone().detach().requires_grad_(True)
    t = t.clone().detach().requires_grad_(True)

    h, u, v = model(x, y, t)

    dhdt = grad(h, t) / T_END_SECONDS
    dhudx = grad(h * u, x) / dem["x_len"]
    dhvdy = grad(h * v, y) / dem["y_len"]

    dhu_dt = grad(h * u, t) / T_END_SECONDS
    dhuu_dx = grad(h * u * u + 0.5 * G * h * h, x) / dem["x_len"]
    dhuv_dy = grad(h * u * v, y) / dem["y_len"]

    dhv_dt = grad(h * v, t) / T_END_SECONDS
    dhuv_dx = grad(h * u * v, x) / dem["x_len"]
    dhvv_dy = grad(h * v * v + 0.5 * G * h * h, y) / dem["y_len"]

    sx = interp_torch(dem["sx_interp"], x, y)
    sy = interp_torch(dem["sy_interp"], x, y)

    rain = rainfall_fn(x, y, t)

    speed = torch.sqrt(u * u + v * v + 1e-8)
    h_safe = torch.clamp(h, min=1e-3)
    n2 = MANNING_N ** 2

    tau_x = G * n2 * u * speed / (h_safe ** (1.0 / 3.0))
    tau_y = G * n2 * v * speed / (h_safe ** (1.0 / 3.0))

    rc = dhdt + dhudx + dhvdy - rain
    rx = dhu_dt + dhuu_dx + dhuv_dy + G * h * sx + tau_x
    ry = dhv_dt + dhuv_dx + dhvv_dy + G * h * sy + tau_y

    return rc, rx, ry

def ic_loss(model):
    x, y, t = sample_ic(N_IC)
    h, u, v = model(x, y, t)
    return ((h - 0.03) ** 2).mean() + (u ** 2).mean() + (v ** 2).mean()

def bc_loss(model):
    bc = sample_bc(N_BC)
    loss = 0.0

    x, y, t = bc["west"]
    h, _, _ = model(x, y, t)
    loss = loss + ((h - SEA_LEVEL) ** 2).mean()

    x, y, t = bc["south"]
    h, _, _ = model(x, y, t)
    loss = loss + ((h - SEA_LEVEL) ** 2).mean()

    x, y, t = bc["east"]
    _, u, _ = model(x, y, t)
    loss = loss + (u ** 2).mean()

    x, y, t = bc["north"]
    _, _, v = model(x, y, t)
    loss = loss + (v ** 2).mean()

    return loss

def data_loss(model, rainfall_fn):
    x, y, t, h_obs = sample_obs(N_OBS, rainfall_fn)
    h, _, _ = model(x, y, t)
    return ((h - h_obs) ** 2).mean()

# ============================================================
# TRAINING
# ============================================================
def train_model(model, dem, rainfall_fn, epochs):
    optimizer = optim.Adam(model.parameters(), lr=1e-3)
    history = {"epoch": [], "total": [], "pde": [], "ic": [], "bc": [], "data": []}
    lam = {"pde": 1.0, "ic": 8.0, "bc": 4.0, "data": 16.0}

    n_params = sum(p.numel() for p in model.parameters())
    print(f"[TRAIN] Parameters: {n_params:,}")

    for ep in range(epochs):
        optimizer.zero_grad()

        x, y, t = sample_uniform(N_INT)
        rc, rx, ry = physics_residual(model, dem, rainfall_fn, x, y, t)
        lpde = ((rc ** 2).mean() + (rx ** 2).mean() + (ry ** 2).mean()) / 3.0
        lic = ic_loss(model)
        lbc = bc_loss(model)
        ldata = data_loss(model, rainfall_fn)

        loss = lam["pde"] * lpde + lam["ic"] * lic + lam["bc"] * lbc + lam["data"] * ldata
        loss.backward()
        torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
        optimizer.step()

        if ep % 50 == 0 or ep == epochs - 1:
            print(
                f"ep {ep:04d} | total={loss.item():.3e} | "
                f"pde={lpde.item():.3e} | ic={lic.item():.3e} | "
                f"bc={lbc.item():.3e} | data={ldata.item():.3e}"
            )
            history["epoch"].append(ep)
            history["total"].append(loss.item())
            history["pde"].append(lpde.item())
            history["ic"].append(lic.item())
            history["bc"].append(lbc.item())
            history["data"].append(ldata.item())

    return history

