def load_outline(path, dem):
    if not os.path.exists(path):
        print("[OUTLINE] GeoJSON not found. Proceeding without boundary mask.")
        return None

    import geopandas as gpd
    from shapely.ops import unary_union
    from shapely.prepared import prep

    gdf = gpd.read_file(path)
    if gdf.crs is None:
        gdf = gdf.set_crs("EPSG:4326")
    else:
        gdf = gdf.to_crs("EPSG:4326")

    geom = unary_union(gdf.geometry).buffer(0)
    prep_geom = prep(geom)

    polys = [geom] if geom.geom_type == "Polygon" else list(geom.geoms)
    patches = []
    for p in polys:
        for ring in [p.exterior] + list(p.interiors):
            lon, lat = np.array(ring.xy)
            xn = (lon - dem["lon_min"]) / (dem["lon_max"] - dem["lon_min"])
            yn = (lat - dem["lat_min"]) / (dem["lat_max"] - dem["lat_min"])
            patches.append((xn, yn))

    print(f"[OUTLINE] Loaded {len(polys)} polygon(s)")
    return {"geom": geom, "prep": prep_geom, "patches": patches}

def draw_outline(ax, outline, color="black", lw=1.2):
    if outline is None:
        return
    for xn, yn in outline["patches"]:
        ax.plot(xn, yn, color=color, lw=lw, zorder=10)

def outline_mask(outline, dem, res):
    if outline is None:
        return None

    xx, yy = np.meshgrid(np.linspace(0, 1, res), np.linspace(0, 1, res))
    lon = dem["lon_min"] + xx * (dem["lon_max"] - dem["lon_min"])
    lat = dem["lat_min"] + yy * (dem["lat_max"] - dem["lat_min"])

    try:
        from shapely import contains_xy
        mask = contains_xy(outline["geom"], lon.ravel(), lat.ravel()).reshape(xx.shape)
    except Exception:
        from shapely.geometry import Point
        mask = np.array([
            outline["prep"].contains(Point(a, b))
            for a, b in zip(lon.ravel(), lat.ravel())
        ]).reshape(xx.shape)

    return mask

# ============================================================
# MODEL
# ============================================================
class FloodPINN(nn.Module):
    def __init__(self, hidden=128, layers=5, fourier=24):
        super().__init__()
        self.register_buffer("B", torch.randn(3, fourier) * 2.0)

        in_dim = 3 + 2 * fourier
        net = []
        d = in_dim
        for _ in range(layers):
            net.append(nn.Linear(d, hidden))
            net.append(nn.Tanh())
            d = hidden
        self.net = nn.Sequential(*net)

        self.head_h = nn.Linear(hidden, 1)
        self.head_u = nn.Linear(hidden, 1)
        self.head_v = nn.Linear(hidden, 1)

        for m in self.modules():
            if isinstance(m, nn.Linear):
                nn.init.xavier_normal_(m.weight)
                nn.init.zeros_(m.bias)

        with torch.no_grad():
            self.head_h.bias.fill_(-4.0)

    def forward(self, x, y, t):
        c = torch.stack([x, y, t], dim=-1)
        proj = c @ self.B
        ff = torch.cat([torch.sin(2 * np.pi * proj), torch.cos(2 * np.pi * proj)], dim=-1)
        z = self.net(torch.cat([c, ff], dim=-1))

        h = F.softplus(self.head_h(z)).squeeze(-1) + 1e-4
        u = 3.0 * torch.tanh(self.head_u(z)).squeeze(-1)
        v = 3.0 * torch.tanh(self.head_v(z)).squeeze(-1)
        return h, u, v

