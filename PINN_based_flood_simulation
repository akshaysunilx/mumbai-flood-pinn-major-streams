    dem_res = get_dem_grid(dem, res)
    dem_bg = get_dem_overlay(dem, res, mode=DEM_OVERLAY_MODE) if OVERLAY_DEM else None
    valid_res = get_valid_grid(dem, res)
    ocean_res = get_ocean_grid(dem, res)
    stream_res = get_stream_overlay(dem, res)
    watershed_res = get_watershed_boundary_overlay(dem, res)
    contour_lvls = compute_contour_levels(dem_res, n_levels=N_CONTOURS)

    vals = []
    for fr in frames_data:
        fld = fr["field"]
        good = fld[np.isfinite(fld)]
        if good.size:
            vals.append(good)
    vmax = max(0.1, safe_percentile(np.concatenate(vals) if vals else np.array([0.1], dtype=np.float32), 99, 0.1))

    if kind == "rain":
        cmap = "Blues"
        cbar_label = "Rainfall (mm/hr)"
    elif kind == "depth":
        cmap = "turbo"
        cbar_label = "Land inundation depth (m)"
    elif kind == "speed":
        cmap = "plasma"
        cbar_label = "Flow speed (m/s)"
    else:
        cmap = "inferno"
        cbar_label = "Unit discharge proxy (m²/s)"

    panel_w, panel_h = get_panel_figsize(dem, base_h=5.3)
    frames = []

    for fr in frames_data:
        field = fr["field"].copy()
        sim_min = fr["t_norm"] * T_END_SECONDS / 60.0
        H_plot = fr.get("depth_for_flow", None)
        Ub = fr.get("Ub", None)
        Vb = fr.get("Vb", None)

        fig, ax = plt.subplots(figsize=(panel_w, panel_h), dpi=130)
        add_context_layers(ax, dem_bg, dem_res, valid_res, ocean_res, stream_res, watershed_res, extent, contour_lvls, xkm, ykm)
        im = ax.imshow(field, extent=extent, origin="lower", cmap=cmap, vmin=0, vmax=vmax, alpha=0.86, aspect="equal")

        if kind in ("depth", "speed", "discharge") and H_plot is not None and Ub is not None and Vb is not None:
            add_flow_overlay(ax, xkm, ykm, Ub, Vb, H_plot)

        ax.set_title(f"{title_prefix}\nTime = {sim_min:.1f} min")
        ax.set_xlabel("Easting (km)")
        ax.set_ylabel("Northing (km)")
        plt.colorbar(im, ax=ax, fraction=0.046, pad=0.03).set_label(cbar_label)
        fig.tight_layout()

        buf = io.BytesIO()
        fig.savefig(buf, format="png", dpi=130)
        plt.close(fig)
        buf.seek(0)
        frames.append(Image.open(buf).convert("P", palette=Image.ADAPTIVE).copy())

    frames[0].save(out_path, save_all=True, append_images=frames[1:], duration=int(1000 / gif_fps), loop=0, optimize=True)
    print(f"[SAVED] {out_path}")

