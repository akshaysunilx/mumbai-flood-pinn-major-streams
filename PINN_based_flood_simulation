def slugify(text):
    return re.sub(r"[^a-zA-Z0-9]+", "_", text.strip()).strip("_").lower()

def safe_percentile(arr, q, default=0.0):
    arr = np.asarray(arr)
    valid = arr[np.isfinite(arr)]
    if valid.size == 0:
        return default
    return float(np.nanpercentile(valid, q))

def rot_gauss_torch(x, y, xc, yc, sx, sy, theta_rad):
    ct = math.cos(theta_rad)
    st = math.sin(theta_rad)
    xr = ct * (x - xc) + st * (y - yc)
    yr = -st * (x - xc) + ct * (y - yc)
    return torch.exp(-0.5 * ((xr / sx) ** 2 + (yr / sy) ** 2))

def get_plot_extent_km(dem):
    return [0.0, dem["x_len"] / 1000.0, 0.0, dem["y_len"] / 1000.0]

def get_panel_figsize(dem, base_h=5.8):
    ratio = dem["x_len"] / max(dem["y_len"], 1e-6)
    panel_w = max(5.8, min(11.0, base_h * ratio))
    return panel_w, base_h

def compute_contour_levels(z, n_levels=10):
    z_valid = z[np.isfinite(z)]
    if z_valid.size < 10:
        return None
    z1, z99 = np.nanpercentile(z_valid, [5, 95])
    relief = z99 - z1
    if relief <= 1e-6:
        return None
    levels = np.linspace(z1, z99, n_levels)
    levels = np.unique(np.round(levels, 2))
    if len(levels) < 2:
        return None
    return levels

def shift_with_fill(arr, dr, dc, fill_value):
    h, w = arr.shape
    out = np.full((h, w), fill_value, dtype=arr.dtype)

    src_r0 = max(0, -dr)
    src_r1 = h - max(0, dr)
    src_c0 = max(0, -dc)
    src_c1 = w - max(0, dc)

    dst_r0 = max(0, dr)
    dst_r1 = h - max(0, -dr)
    dst_c0 = max(0, dc)
    dst_c1 = w - max(0, -dc)

    out[dst_r0:dst_r1, dst_c0:dst_c1] = arr[src_r0:src_r1, src_c0:src_c1]
    return out

def weighted_mean_torch(values, weights, eps=1e-8):
    return (values * weights).sum() / torch.clamp(weights.sum(), min=eps)

def np_to_torch(x):
    return torch.from_numpy(np.asarray(x, dtype=np.float32)).to(DEVICE)

