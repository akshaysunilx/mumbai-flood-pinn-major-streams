def get_resampled_from_interp(interp_fn, res):
    xi = np.linspace(0.0, 1.0, res)
    yi = np.linspace(0.0, 1.0, res)
    xx, yy = np.meshgrid(xi, yi)
    pts = np.stack([yy.ravel(), xx.ravel()], axis=-1)
    return interp_fn(pts).reshape(res, res).astype(np.float32)

def get_dem_grid(dem, res):
    return get_resampled_from_interp(dem["elev_interp"], res)

def get_valid_grid(dem, res):
    return get_resampled_from_interp(dem["valid_interp"], res)

def get_ocean_grid(dem, res):
    return get_resampled_from_interp(dem["ocean_mask_interp"], res)

def get_sea_base_grid(dem, res):
    return get_resampled_from_interp(dem["sea_base_interp"], res)

def get_stream_overlay(dem, res):
    channel = get_resampled_from_interp(dem["channel_strength_interp"], res)
    # Binary stream overlay derived from D8 flow accumulation / watershed-guided drainage
    return (channel > 0.05).astype(np.float32)

def get_watershed_boundary_overlay(dem, res):
    return get_resampled_from_interp(dem["watershed_boundary_interp"], res)

def get_dir_overlay(dem, res):
    dirx = get_resampled_from_interp(dem["dirx_interp"], res)
    diry = get_resampled_from_interp(dem["diry_interp"], res)
    mag = np.sqrt(dirx ** 2 + diry ** 2)
    good = mag > 1e-6
    dirx[good] /= mag[good]
    diry[good] /= mag[good]
    return dirx, diry

def make_hillshade(z, azdeg=315, altdeg=45, vert_exag=4.0):
    z = np.asarray(z, dtype=np.float32)
    z = np.nan_to_num(z, nan=np.nanmedian(z))
    z = gaussian_filter(z, sigma=1.0) * vert_exag
    dy, dx = np.gradient(z)
    slope = np.pi / 2.0 - np.arctan(np.sqrt(dx * dx + dy * dy))
    aspect = np.arctan2(-dx, dy)
    az, alt = np.deg2rad(azdeg), np.deg2rad(altdeg)
    hs = np.sin(alt) * np.sin(slope) + np.cos(alt) * np.cos(slope) * np.cos(az - aspect)
    return np.clip(hs, 0, 1)

def get_dem_overlay(dem, res, mode="hillshade"):
    z = get_dem_grid(dem, res)
    if mode == "elevation":
        zmin, zmax = safe_percentile(z, 2, 0.0), safe_percentile(z, 98, 1.0)
        return np.clip((z - zmin) / max(zmax - zmin, 1e-6), 0, 1) if zmax > zmin else np.zeros_like(z)
    return make_hillshade(z, vert_exag=HILLSHADE_EXAG)

# ============================================================
# MODEL
# ============================================================
class FloodPINN(nn.Module):
    def __init__(self, hidden=HIDDEN, layers=LAYERS, fourier=FOURIER, terrain_features=TERRAIN_FEATURES):
        super().__init__()
        self.register_buffer("B", torch.randn(3, fourier) * 2.0)

        in_dim = 3 + 2 * fourier + terrain_features
        mods = []
        d = in_dim
        for _ in range(layers):
            mods.append(nn.Linear(d, hidden))
            mods.append(nn.Tanh())
            d = hidden
        self.net = nn.Sequential(*mods)

        self.head_h = nn.Linear(hidden, 1)
        self.head_u = nn.Linear(hidden, 1)
        self.head_v = nn.Linear(hidden, 1)

        for m in self.modules():
            if isinstance(m, nn.Linear):
                nn.init.xavier_normal_(m.weight)
                nn.init.zeros_(m.bias)

        with torch.no_grad():
            self.head_h.bias.fill_(-5.2)

    def forward(self, x, y, t, terrain):
        c = torch.stack([x, y, t], dim=-1)
        proj = c @ self.B
        ff = torch.cat([torch.sin(2 * np.pi * proj), torch.cos(2 * np.pi * proj)], dim=-1)
        z = self.net(torch.cat([c, ff, terrain], dim=-1))

        h_dyn = F.softplus(self.head_h(z)).squeeze(-1)
        u = 3.8 * torch.tanh(self.head_u(z)).squeeze(-1)
        v = 3.8 * torch.tanh(self.head_v(z)).squeeze(-1)
        return h_dyn, u, v

def evaluate_model_total(model, dem, x, y, t):
    terrain = get_terrain_features_torch(dem, x, y)
    h_dyn, u, v = model(x, y, t, terrain)
    sea_base = sample_field_torch(dem["sea_base_tensor"], x, y)
    h_total = h_dyn + sea_base
    return h_total, h_dyn, u, v, sea_base

# ============================================================
# PHYSICS RESIDUAL
# ============================================================
def grad(out, inp):
    return torch.autograd.grad(
        out,
        inp,
        grad_outputs=torch.ones_like(out),
        create_graph=True,
        retain_graph=True,
    )[0]

def physics_residual(model, dem, rainfall_fn, x, y, t):
    x = x.clone().detach().requires_grad_(True)
    y = y.clone().detach().requires_grad_(True)
    t = t.clone().detach().requires_grad_(True)

    h_total, h_dyn, u, v, sea_base = evaluate_model_total(model, dem, x, y, t)
    qx = h_total * u
    qy = h_total * v

    dhdt = grad(h_total, t) / T_END_SECONDS
    dqx_dx = grad(qx, x) / dem["x_len"]
    dqy_dy = grad(qy, y) / dem["y_len"]

    dqxu_dt = grad(qx, t) / T_END_SECONDS
    dmx_dx = grad(h_total * u * u + 0.5 * G * h_total * h_total, x) / dem["x_len"]
    dmx_dy = grad(h_total * u * v, y) / dem["y_len"]

    dqyv_dt = grad(qy, t) / T_END_SECONDS
    dmy_dx = grad(h_total * u * v, x) / dem["x_len"]
    dmy_dy = grad(h_total * v * v + 0.5 * G * h_total * h_total, y) / dem["y_len"]

    sx = sample_field_torch(dem["sx_tensor"], x, y)
    sy = sample_field_torch(dem["sy_tensor"], x, y)
    rain = rainfall_fn(x, y, t)

    speed = torch.sqrt(u * u + v * v + 1e-8)
    h_safe = torch.clamp(h_total, min=1e-3)
    n2 = MANNING_N ** 2
    tau_x = G * n2 * u * speed / (h_safe ** (1.0 / 3.0))
    tau_y = G * n2 * v * speed / (h_safe ** (1.0 / 3.0))

    rc = dhdt + dqx_dx + dqy_dy - rain
    rx = dqxu_dt + dmx_dx + dmx_dy + G * h_total * sx + tau_x
    ry = dqyv_dt + dmy_dx + dmy_dy + G * h_total * sy + tau_y
    return rc, rx, ry

