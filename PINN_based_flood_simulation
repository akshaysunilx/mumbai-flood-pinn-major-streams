# TRAINING
# ============================================================
def train_model(model, dem, mesh, rainfall_fn, epochs):
    optimizer = optim.AdamW(model.parameters(), lr=1.0e-3, weight_decay=1.0e-6)
    scheduler = optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=epochs, eta_min=2.0e-4)

    history = {k: [] for k in (
        "epoch", "total", "pde", "ic", "bc", "data",
        "channel", "pluvial", "align", "dry", "ocean", "qguide", "lr"
    )}

    lam = {
        "pde": 1.0,
        "ic": 8.0,
        "bc": 4.0,
        "data": 16.0,
        "channel": 3.8,
        "pluvial": 4.6,
        "align": 1.4,
        "dry": 2.2,
        "ocean": 12.0,
        "qguide": 1.2,
    }

    print(f"[TRAIN] Parameters: {sum(p.numel() for p in model.parameters()):,}")

    for ep in range(epochs):
        optimizer.zero_grad()

        x, y, t, pde_w = sample_structured_pde_points(N_INT, mesh)
        rc, rx, ry = physics_residual(model, dem, rainfall_fn, x, y, t)
        lpde = (
            weighted_mean_torch(rc ** 2, pde_w) +
            weighted_mean_torch(rx ** 2, pde_w) +
            weighted_mean_torch(ry ** 2, pde_w)
        ) / 3.0

        lic = ic_loss(model, dem, mesh)
        lbc = bc_loss(model, dem, mesh)
        ldata = data_loss(model, rainfall_fn, dem, mesh)
        lch = channel_guidance_loss(model, rainfall_fn, dem, mesh)
        lpluvial = pluvial_spread_loss(model, rainfall_fn, dem, mesh)
        lalign = terrain_alignment_loss(model, rainfall_fn, dem, mesh)
        ldry = dry_suppression_loss(model, rainfall_fn, dem, mesh)
        locean = ocean_consistency_loss(model, rainfall_fn, dem, mesh)
        lqguide = discharge_guidance_loss(model, rainfall_fn, dem, mesh)

        loss = (
            lam["pde"] * lpde +
            lam["ic"] * lic +
            lam["bc"] * lbc +
            lam["data"] * ldata +
            lam["channel"] * lch +
            lam["pluvial"] * lpluvial +
            lam["align"] * lalign +
            lam["dry"] * ldry +
            lam["ocean"] * locean +
            lam["qguide"] * lqguide
        )

        loss.backward()
        torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
        optimizer.step()
        scheduler.step()

        if ep % 25 == 0 or ep == epochs - 1:
            lr = scheduler.get_last_lr()[0]
            print(
                f"ep {ep:04d} | total={loss.item():.3e} | pde={lpde.item():.3e} | "
                f"ic={lic.item():.3e} | bc={lbc.item():.3e} | data={ldata.item():.3e} | "
                f"channel={lch.item():.3e} | pluvial={lpluvial.item():.3e} | "
                f"align={lalign.item():.3e} | dry={ldry.item():.3e} | ocean={locean.item():.3e} | "
                f"qguide={lqguide.item():.3e} | lr={lr:.2e}"
            )
            for k, v in zip(
                ("epoch", "total", "pde", "ic", "bc", "data", "channel", "pluvial", "align", "dry", "ocean", "qguide", "lr"),
                (ep, loss.item(), lpde.item(), lic.item(), lbc.item(), ldata.item(), lch.item(), lpluvial.item(), lalign.item(), ldry.item(), locean.item(), lqguide.item(), lr)
            ):
                history[k].append(v)

    return history

