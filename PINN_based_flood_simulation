def build_hydraulic_mesh(dem, mesh_m=HYDRAULIC_MESH_M):
    nx_cells = max(8, int(np.ceil(dem["x_len"] / mesh_m)))
    ny_cells = max(8, int(np.ceil(dem["y_len"] / mesh_m)))

    x_centers = (np.arange(nx_cells, dtype=np.float32) + 0.5) / nx_cells
    y_centers = (np.arange(ny_cells, dtype=np.float32) + 0.5) / ny_cells
    xx, yy = np.meshgrid(x_centers, y_centers)
    pts = np.stack([yy.ravel(), xx.ravel()], axis=-1)

    valid = dem["valid_interp"](pts).reshape(ny_cells, nx_cells)
    ocean = dem["ocean_mask_interp"](pts).reshape(ny_cells, nx_cells)
    acc = dem["acc_interp"](pts).reshape(ny_cells, nx_cells)
    lowland = dem["lowland_interp"](pts).reshape(ny_cells, nx_cells)
    channel_strength = dem["channel_strength_interp"](pts).reshape(ny_cells, nx_cells)
    channel_prox = dem["channel_prox_interp"](pts).reshape(ny_cells, nx_cells)

    valid_mask = valid > 0.5
    ocean_mask = ocean > 0.5
    land_mask = valid_mask & (~ocean_mask)
    channel_mask = land_mask & (channel_strength > 0.05)
    floodplain_mask = land_mask & ((lowland > 0.55) | (channel_prox > 0.25))
    upland_mask = land_mask & (~floodplain_mask)

    hydro_score = np.zeros_like(acc, dtype=np.float32)
    hydro_score[land_mask] = (
        0.30 +
        0.34 * acc[land_mask] +
        0.24 * lowland[land_mask] +
        0.12 * channel_strength[land_mask]
    )
    hydro_score = np.clip(hydro_score, 0.0, None)

    flat_ids = np.arange(nx_cells * ny_cells, dtype=np.int64)
    flat_land = flat_ids[land_mask.ravel()]
    flat_ocean = flat_ids[(valid_mask & ocean_mask).ravel()]
    flat_channel = flat_ids[channel_mask.ravel()]
    flat_flood = flat_ids[floodplain_mask.ravel()]
    flat_upland = flat_ids[upland_mask.ravel()]

    def flat_from_mask(mask):
        return flat_ids[mask.ravel()]

    west_ids = flat_from_mask(land_mask & (np.arange(nx_cells)[None, :] == 0))
    east_ids = flat_from_mask(land_mask & (np.arange(nx_cells)[None, :] == (nx_cells - 1)))
    south_ids = flat_from_mask(land_mask & (np.arange(ny_cells)[:, None] == 0))
    north_ids = flat_from_mask(land_mask & (np.arange(ny_cells)[:, None] == (ny_cells - 1)))

    flat_acc = acc.ravel().astype(np.float32)
    flat_lowland = lowland.ravel().astype(np.float32)
    flat_channel_strength = channel_strength.ravel().astype(np.float32)
    flat_hydro = hydro_score.ravel().astype(np.float32)

    def weights_for(ids, base=0.05, use="hydro"):
        if ids.size == 0:
            return np.array([], dtype=np.float32)
        if use == "hydro":
            w = base + flat_hydro[ids]
        elif use == "channel":
            w = base + 0.60 * flat_channel_strength[ids] + 0.30 * flat_acc[ids] + 0.10 * flat_lowland[ids]
        elif use == "flood":
            w = base + 0.45 * flat_lowland[ids] + 0.35 * flat_acc[ids] + 0.20 * flat_channel_strength[ids]
        elif use == "dry":
            w = base + (1.0 - flat_acc[ids]) * 0.55 + (1.0 - flat_lowland[ids]) * 0.45
        else:
            w = np.ones(ids.shape[0], dtype=np.float32)
        w = np.clip(w, 1e-6, None)
        return w / w.sum()

    mesh = {
        "mesh_m": mesh_m,
        "nx_cells": nx_cells,
        "ny_cells": ny_cells,
        "dx_norm": 1.0 / nx_cells,
        "dy_norm": 1.0 / ny_cells,
        "x_centers": x_centers,
        "y_centers": y_centers,
        "valid_mask": valid_mask,
        "ocean_mask": ocean_mask,
        "land_mask": land_mask,
        "channel_mask": channel_mask,
        "floodplain_mask": floodplain_mask,
        "upland_mask": upland_mask,
        "hydro_score": hydro_score,
        "flat_land": flat_land,
        "flat_ocean": flat_ocean,
        "flat_channel": flat_channel,
        "flat_flood": flat_flood,
        "flat_upland": flat_upland,
        "west_ids": west_ids,
        "east_ids": east_ids,
        "south_ids": south_ids,
        "north_ids": north_ids,
        "flat_acc": flat_acc,
        "flat_lowland": flat_lowland,
        "flat_channel_strength": flat_channel_strength,
        "flat_hydro": flat_hydro,
        "land_weights": weights_for(flat_land, use="hydro"),
        "channel_weights": weights_for(flat_channel, use="channel"),
        "flood_weights": weights_for(flat_flood, use="flood"),
        "dry_weights": weights_for(flat_upland, use="dry"),
        "ocean_weights": weights_for(flat_ocean, use="uniform"),
    }

    print(f"[MESH] Hydraulic training mesh: {nx_cells} x {ny_cells} cells")
    print(f"[MESH] Nominal cell size: ~{dem['x_len']/nx_cells:.1f} m x {dem['y_len']/ny_cells:.1f} m")
    print(f"[MESH] Land cells: {flat_land.size} | Channel cells: {flat_channel.size} | Floodplain cells: {flat_flood.size}")
    return mesh

def _sample_ids(ids, weights, n, fallback_ids, fallback_weights):
    if ids.size == 0:
        ids = fallback_ids
        weights = fallback_weights
    if ids.size == 0:
        raise RuntimeError("No valid mesh cells available for sampling.")
    if weights is None or weights.size == 0:
        return np.random.choice(ids, size=n, replace=True)
    return np.random.choice(ids, size=n, replace=True, p=weights)

def _points_from_cell_ids(mesh, ids, side=None):
    n = ids.shape[0]
    ny = mesh["ny_cells"]
    nx = mesh["nx_cells"]
    rows = ids // nx
    cols = ids % nx

    if side is None:
        tpl = POINT_TEMPLATES[np.random.randint(0, len(POINT_TEMPLATES), size=n)]
        jx = np.random.normal(0.0, MESH_JITTER_FRAC, size=n).astype(np.float32)
        jy = np.random.normal(0.0, MESH_JITTER_FRAC, size=n).astype(np.float32)
        x = (cols.astype(np.float32) + 0.5 + tpl[:, 0] + jx) / nx
        y = (rows.astype(np.float32) + 0.5 + tpl[:, 1] + jy) / ny
    else:
        if side == "west":
            x = np.full(n, 1e-4, dtype=np.float32)
            y = (rows.astype(np.float32) + np.random.rand(n).astype(np.float32)) / ny
        elif side == "east":
            x = np.full(n, 1.0 - 1e-4, dtype=np.float32)
            y = (rows.astype(np.float32) + np.random.rand(n).astype(np.float32)) / ny
        elif side == "south":
            x = (cols.astype(np.float32) + np.random.rand(n).astype(np.float32)) / nx
            y = np.full(n, 1e-4, dtype=np.float32)
        else:
            x = (cols.astype(np.float32) + np.random.rand(n).astype(np.float32)) / nx
            y = np.full(n, 1.0 - 1e-4, dtype=np.float32)

    x = np.clip(x, 0.0, 1.0)
    y = np.clip(y, 0.0, 1.0)
    return x.astype(np.float32), y.astype(np.float32)

def sample_structured_pde_points(n, mesh):
    n_ch = int(0.42 * n)
    n_fp = int(0.28 * n)
    n_ld = n - n_ch - n_fp

    ids = np.concatenate([
        _sample_ids(mesh["flat_channel"], mesh["channel_weights"], n_ch, mesh["flat_land"], mesh["land_weights"]),
        _sample_ids(mesh["flat_flood"], mesh["flood_weights"], n_fp, mesh["flat_land"], mesh["land_weights"]),
        _sample_ids(mesh["flat_land"], mesh["land_weights"], n_ld, mesh["flat_land"], mesh["land_weights"]),
    ])
    np.random.shuffle(ids)
    x, y = _points_from_cell_ids(mesh, ids)
    t = np.random.rand(n).astype(np.float32)
    w = (0.20 + 0.45 * mesh["flat_channel_strength"][ids] + 0.20 * mesh["flat_lowland"][ids] + 0.15 * mesh["flat_acc"][ids]).astype(np.float32)
    return np_to_torch(x), np_to_torch(y), np_to_torch(t), np_to_torch(w)

