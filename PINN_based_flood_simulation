def build_rainfall_fn(case):
    peak_mmhr = float(case.get("peak_mmhr", 140.0))
    citywide_amp = float(case.get("citywide_amp", 1.0))
    shield_amp = float(case.get("shield_amp", 1.0))
    band_amp = float(case.get("band_amp", 0.7))
    cell_amp = float(case.get("cell_amp", 0.5))
    coast_amp = float(case.get("coast_amp", 0.3))
    corridor_amp = float(case.get("corridor_amp", 0.25))
    shift_x = float(case.get("shift_x", 0.0))
    shift_y = float(case.get("shift_y", 0.0))
    temporal_shift = float(case.get("temporal_shift", 0.0))
    duration_scale = float(case.get("duration_scale", 1.0))
    band_rotation = float(case.get("band_rotation", 0.0))

    def rainfall(x, y, t):
        tt = torch.clamp(t + temporal_shift, 0.0, 1.0)

        s1 = 0.13 * duration_scale
        s2 = 0.16 * duration_scale
        s3 = 0.14 * duration_scale

        p1 = torch.exp(-0.5 * ((tt - 0.20) / s1) ** 2)
        p2 = torch.exp(-0.5 * ((tt - 0.48) / s2) ** 2)
        p3 = torch.exp(-0.5 * ((tt - 0.77) / s3) ** 2)
        temporal = 0.58 * p1 + 1.00 * p2 + 0.78 * p3
        temporal = temporal * (0.94 + 0.06 * torch.sin(2.0 * np.pi * (2.3 * tt + 0.10)))

        broad1 = rot_gauss_torch(x, y, 0.45 + 0.02 * tt + shift_x, 0.56 + shift_y, 0.60, 0.44, -0.12 + band_rotation)
        broad2 = rot_gauss_torch(x, y, 0.58 - 0.03 * tt + shift_x, 0.46 + 0.02 * tt + shift_y, 0.52, 0.36, -0.20 + band_rotation)
        citywide = 0.64 + 0.70 * broad1 + 0.45 * broad2

        shield1 = rot_gauss_torch(x, y, 0.34 + 0.12 * tt + shift_x, 0.74 - 0.06 * tt + shift_y, 0.34, 0.22, -0.52 + band_rotation)
        shield2 = rot_gauss_torch(x, y, 0.58 - 0.05 * tt + shift_x, 0.52 + shift_y, 0.30, 0.24, -0.36 + band_rotation)
        shield3 = rot_gauss_torch(x, y, 0.78 - 0.04 * tt + shift_x, 0.38 + 0.03 * tt + shift_y, 0.25, 0.20, -0.18 + band_rotation)
        mesoscale = 0.80 * shield1 + 0.70 * shield2 + 0.45 * shield3

        band1 = rot_gauss_torch(x, y, 0.22 + 0.18 * tt + shift_x, 0.78 - 0.12 * tt + shift_y, 0.46, 0.08, -0.84 + band_rotation)
        band2 = rot_gauss_torch(x, y, 0.34 + 0.16 * tt + shift_x, 0.60 - 0.07 * tt + shift_y, 0.44, 0.08, -0.80 + band_rotation)
        band3 = rot_gauss_torch(x, y, 0.48 + 0.12 * tt + shift_x, 0.44 + shift_y, 0.36, 0.075, -0.72 + band_rotation)
        east_band = rot_gauss_torch(x, y, 0.84 - 0.03 * tt + shift_x, 0.52 + 0.04 * tt + shift_y, 0.18, 0.24, 0.12 + band_rotation)
        bands = 0.82 * band1 + 0.72 * band2 + 0.58 * band3 + 0.34 * east_band

        c1 = rot_gauss_torch(x, y, 0.18 + 0.20 * tt + shift_x, 0.83 - 0.14 * tt + shift_y, 0.065, 0.048, -0.28)
        c2 = rot_gauss_torch(x, y, 0.32 + 0.18 * tt + shift_x, 0.68 - 0.11 * tt + shift_y, 0.058, 0.042, 0.10)
        c3 = rot_gauss_torch(x, y, 0.48 + 0.10 * tt + shift_x, 0.57 - 0.05 * tt + shift_y, 0.055, 0.040, -0.18)
        c4 = rot_gauss_torch(x, y, 0.62 - 0.05 * tt + shift_x, 0.45 + 0.02 * tt + shift_y, 0.056, 0.042, 0.32)
        c5 = rot_gauss_torch(x, y, 0.73 - 0.08 * tt + shift_x, 0.32 + 0.05 * tt + shift_y, 0.064, 0.046, -0.16)
        c6 = rot_gauss_torch(x, y, 0.86 - 0.02 * tt + shift_x, 0.55 + 0.01 * tt + shift_y, 0.050, 0.050, 0.12)
        cells = 1.00 * c1 + 0.95 * c2 + 0.90 * c3 + 0.80 * c4 + 0.72 * c5 + 0.55 * c6

        coast = rot_gauss_torch(x, y, 0.17 + 0.03 * tt + 0.4 * shift_x, 0.46 + shift_y, 0.16, 0.40, -0.06)
        mithi_corridor = torch.exp(-((x - (0.50 + shift_x)) / 0.10) ** 2) * torch.exp(-((y - (0.42 + shift_y)) / 0.14) ** 2)
        kurla_dharavi = torch.exp(-((x - (0.46 + shift_x)) / 0.09) ** 2) * torch.exp(-((y - (0.39 + shift_y)) / 0.09) ** 2)
        thane_creek = torch.exp(-((x - (0.86 + shift_x)) / 0.11) ** 2) * torch.exp(-((y - (0.50 + shift_y)) / 0.14) ** 2)
        corridor = 0.55 * mithi_corridor + 0.25 * kurla_dharavi + 0.20 * thane_creek

        gradient = 0.94 + 0.05 * y + 0.03 * (1.0 - x)

        spatial = (
            citywide_amp * citywide +
            shield_amp * 0.66 * mesoscale +
            band_amp * 0.62 * bands +
            cell_amp * 0.48 * cells +
            coast_amp * 0.24 * coast +
            corridor_amp * 0.24 * corridor
        ) * gradient

        return (peak_mmhr / 1000.0 / 3600.0) * temporal * spatial

    return rainfall

