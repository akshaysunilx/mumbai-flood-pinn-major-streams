def sample_boundary_side(side, n, mesh):
    if side == "west":
        ids = mesh["west_ids"]
    elif side == "east":
        ids = mesh["east_ids"]
    elif side == "south":
        ids = mesh["south_ids"]
    else:
        ids = mesh["north_ids"]

    if ids.size == 0:
        ids = mesh["flat_land"]

    sampled = np.random.choice(ids, size=n, replace=True)
    x, y = _points_from_cell_ids(mesh, sampled, side=side)
    t = np.random.rand(n).astype(np.float32)
