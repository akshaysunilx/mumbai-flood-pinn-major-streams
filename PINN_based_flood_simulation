@torch.no_grad()
def predict_field(model, dem, t_norm, res, batch_size=PRED_BATCH_SIZE):
    xi = np.linspace(0.0, 1.0, res)
    yi = np.linspace(0.0, 1.0, res)
    xx, yy = np.meshgrid(xi, yi)
    x_all = xx.ravel().astype(np.float32)
    y_all = yy.ravel().astype(np.float32)
    n = x_all.size

    H_dyn = np.empty(n, np.float32)
    U = np.empty(n, np.float32)
    V = np.empty(n, np.float32)

    for i0 in range(0, n, batch_size):
        i1 = min(i0 + batch_size, n)
        xb = torch.from_numpy(x_all[i0:i1]).to(DEVICE)
        yb = torch.from_numpy(y_all[i0:i1]).to(DEVICE)
        tb = torch.full_like(xb, float(t_norm))
        terrain = get_terrain_features_torch(dem, xb, yb)
        h_dyn, u, v = model(xb, yb, tb, terrain)
        H_dyn[i0:i1] = h_dyn.cpu().numpy()
        U[i0:i1] = u.cpu().numpy()
        V[i0:i1] = v.cpu().numpy()

    H_dyn = H_dyn.reshape(res, res)
    U = U.reshape(res, res)
    V = V.reshape(res, res)

    sea_base = get_sea_base_grid(dem, res)
    ocean_res = get_ocean_grid(dem, res)
    valid_res = get_valid_grid(dem, res)

    H_total = H_dyn + sea_base
    H_total[valid_res < 0.5] = np.nan

    H_flood_land = H_dyn.copy()
    H_flood_land[ocean_res >= 0.5] = np.nan
    H_flood_land[valid_res < 0.5] = np.nan
    H_flood_land[H_flood_land < 0] = 0.0

    return xi, yi, H_total, H_flood_land, U, V, sea_base, ocean_res, valid_res

@torch.no_grad()
def predict_native_field(model, dem, t_norm, batch_size=PRED_BATCH_SIZE):
    w, h = dem["w"], dem["h"]
    xi = np.linspace(0.0, 1.0, w)
    yi = np.linspace(0.0, 1.0, h)
    xx, yy = np.meshgrid(xi, yi)
    x_all = xx.ravel().astype(np.float32)
    y_all = yy.ravel().astype(np.float32)
    n = x_all.size

    H_dyn = np.empty(n, np.float32)
    U = np.empty(n, np.float32)
    V = np.empty(n, np.float32)

    for i0 in range(0, n, batch_size):
        i1 = min(i0 + batch_size, n)
        xb = torch.from_numpy(x_all[i0:i1]).to(DEVICE)
        yb = torch.from_numpy(y_all[i0:i1]).to(DEVICE)
        tb = torch.full_like(xb, float(t_norm))
        terrain = get_terrain_features_torch(dem, xb, yb)
        hd, u, v = model(xb, yb, tb, terrain)
        H_dyn[i0:i1] = hd.cpu().numpy()
        U[i0:i1] = u.cpu().numpy()
        V[i0:i1] = v.cpu().numpy()

    H_dyn = H_dyn.reshape(h, w)
    U = U.reshape(h, w)
    V = V.reshape(h, w)

    H_total = H_dyn + dem["sea_base"]
    H_total[~dem["valid_mask"]] = np.nan

    H_flood_land = H_dyn.copy()
    H_flood_land[dem["ocean_mask"]] = np.nan
    H_flood_land[~dem["valid_mask"]] = np.nan
    H_flood_land[H_flood_land < 0] = 0.0
    return H_total, H_flood_land, U, V

@torch.no_grad()
def rainfall_grid(rainfall_fn, t_norm, res, batch_size=PRED_BATCH_SIZE):
    xi = np.linspace(0.0, 1.0, res)
    yi = np.linspace(0.0, 1.0, res)
    xx, yy = np.meshgrid(xi, yi)
    x_all = xx.ravel().astype(np.float32)
    y_all = yy.ravel().astype(np.float32)
    n = x_all.size
    R = np.empty(n, np.float32)
    for i0 in range(0, n, batch_size):
        i1 = min(i0 + batch_size, n)
        xb = torch.from_numpy(x_all[i0:i1]).to(DEVICE)
        yb = torch.from_numpy(y_all[i0:i1]).to(DEVICE)
        tb = torch.full_like(xb, float(t_norm))
        R[i0:i1] = rainfall_fn(xb, yb, tb).cpu().numpy() * 1000.0 * 3600.0
    return xi, yi, R.reshape(res, res)

def blend_flow_for_display(U, V, H_flood_land, dirx_res, diry_res):
    speed = np.sqrt(U ** 2 + V ** 2)
    wet = np.isfinite(H_flood_land) & (H_flood_land > WET_DEPTH_THRESHOLD)
    tb = np.clip(np.nan_to_num(H_flood_land, nan=0.0) / 0.18, 0.0, 1.0)
    Ub = 0.55 * U + 0.45 * dirx_res * (0.50 + 0.90 * tb + 0.25 * speed)
    Vb = 0.55 * V + 0.45 * diry_res * (0.50 + 0.90 * tb + 0.25 * speed)
    Ub[~wet] = np.nan
    Vb[~wet] = np.nan
    return Ub, Vb

def peak_speed_from_fields(flood_fields, u_fields, v_fields, ocean_res):
    stk = []
    for H, U, V in zip(flood_fields, u_fields, v_fields):
        S = np.sqrt(U ** 2 + V ** 2)
        S[~np.isfinite(H)] = np.nan
        S[H <= WET_DEPTH_THRESHOLD] = np.nan
        stk.append(np.where(np.isfinite(S), S, -np.inf))
    peak = np.max(np.stack(stk, axis=0), axis=0)
    peak[peak == -np.inf] = np.nan
    peak[ocean_res >= 0.5] = np.nan
    return peak

def peak_discharge_from_fields(flood_fields, u_fields, v_fields, ocean_res):
    stk = []
    for H, U, V in zip(flood_fields, u_fields, v_fields):
        Q = H * np.sqrt(U ** 2 + V ** 2)
        Q[~np.isfinite(H)] = np.nan
        Q[H <= WET_DEPTH_THRESHOLD] = np.nan
        stk.append(np.where(np.isfinite(Q), Q, -np.inf))
    peak = np.max(np.stack(stk, axis=0), axis=0)
    peak[peak == -np.inf] = np.nan
    peak[ocean_res >= 0.5] = np.nan
    return peak

def arrival_time_from_fields(flood_fields, tvals, ocean_res, threshold=ARRIVAL_DEPTH_THRESHOLD):
    nt = len(flood_fields)
    arr = np.full(flood_fields[0].shape, np.nan, dtype=np.float32)
    for k in range(nt):
        H = flood_fields[k]
        hit = np.isnan(arr) & np.isfinite(H) & (H >= threshold)
        arr[hit] = tvals[k] * T_END_SECONDS / 60.0
    arr[ocean_res >= 0.5] = np.nan
    return arr

