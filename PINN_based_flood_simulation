def ocean_rgba_image(ocean_res):
    rgba = np.zeros((*ocean_res.shape, 4), dtype=np.float32)
    m = ocean_res >= 0.5
    rgba[m] = SEA_FILL_RGBA
    return rgba

def add_context_layers(ax, dem_bg, dem_res, valid_res, ocean_res, stream_res, watershed_res, extent, contour_levels, xkm, ykm):
    Xkm, Ykm = np.meshgrid(xkm, ykm)
    if SHOW_SEA_FILL:
        ax.imshow(ocean_rgba_image(ocean_res), extent=extent, origin="lower", aspect="equal")
    if OVERLAY_DEM and dem_bg is not None:
        ax.imshow(dem_bg, extent=extent, origin="lower", cmap="gray", alpha=DEM_OVERLAY_ALPHA, aspect="equal")
    if SHOW_CONTOURS and contour_levels is not None:
        ax.contour(Xkm, Ykm, dem_res, levels=contour_levels, colors="0.35", linewidths=CONTOUR_LW, alpha=CONTOUR_ALPHA)
    if SHOW_STREAM_NETWORK and np.nanmax(stream_res) > 0.5:
        ax.contour(Xkm, Ykm, stream_res, levels=[0.5], colors="navy", linewidths=STREAM_LW, alpha=STREAM_ALPHA)
    if SHOW_WATERSHED_BOUNDARIES and np.nanmax(watershed_res) > 0.5:
        ax.contour(Xkm, Ykm, watershed_res, levels=[0.5], colors=WATERSHED_COLOR, linewidths=WATERSHED_LW, alpha=WATERSHED_ALPHA)
    if SHOW_DOMAIN_BOUNDARY and np.nanmin(valid_res) < 0.5 < np.nanmax(valid_res):
        ax.contour(Xkm, Ykm, valid_res, levels=[0.5], colors="black", linewidths=BOUNDARY_LW, alpha=BOUNDARY_ALPHA)
    if SHOW_COASTLINE and np.nanmin(ocean_res) < 0.5 < np.nanmax(ocean_res):
        ax.contour(Xkm, Ykm, ocean_res, levels=[0.5], colors=COASTLINE_COLOR, linewidths=COASTLINE_LW, alpha=COASTLINE_ALPHA)
    ax.set_xlim(extent[0], extent[1])
    ax.set_ylim(extent[2], extent[3])

def add_flow_overlay(ax, xkm, ykm, Ub, Vb, H_plot):
    if not SHOW_VELOCITY:
        return
    wet = np.isfinite(H_plot) & (H_plot > WET_DEPTH_THRESHOLD)
    if wet.sum() < 15:
        return

    if SHOW_STREAMLINES:
        try:
            Upl = np.ma.masked_where(~wet | ~np.isfinite(Ub), Ub)
            Vpl = np.ma.masked_where(~wet | ~np.isfinite(Vb), Vb)
            ax.streamplot(
                xkm, ykm, Upl, Vpl,
                density=STREAMLINE_DENSITY,
                color="k",
                linewidth=STREAMLINE_WIDTH,
                arrowsize=0.85,
                minlength=0.08,
                maxlength=2.6,
                broken_streamlines=True,
                integration_direction="both",
                zorder=8,
            )
        except Exception:
            pass

    s = VELOCITY_QUIVER_STEP
    Xq, Yq = np.meshgrid(xkm[::s], ykm[::s])
    Uq, Vq = Ub[::s, ::s], Vb[::s, ::s]
    Hq = H_plot[::s, ::s]
    wet_q = np.isfinite(Hq) & (Hq > WET_DEPTH_THRESHOLD)
    if wet_q.any():
        spd = np.sqrt(Uq ** 2 + Vq ** 2)
        ax.quiver(
            Xq[wet_q], Yq[wet_q],
            Uq[wet_q] / (spd[wet_q] + 1e-6),
            Vq[wet_q] / (spd[wet_q] + 1e-6),
            color="k", alpha=VELOCITY_ALPHA, scale=VELOCITY_SCALE,
            width=0.0018, headwidth=2.8, headlength=4.0, zorder=9,
        )

