# SYNTHETIC GUIDANCE / LOSSES
# ============================================================
def sample_obs(n, rainfall_fn, dem, mesh):
    n_hot = int(0.44 * n)
    n_fp = int(0.30 * n)
    n_bg = max(1, n - n_hot - n_fp)

    x1, y1, t1, _ = sample_channel_mesh(n_hot, mesh)
    x2, y2, t2, _ = sample_floodplain_mesh(n_fp, mesh)
    x3, y3, t3, _ = sample_land_mesh(n_bg, mesh)

    x = torch.cat([x1, x2, x3], dim=0)
    y = torch.cat([y1, y2, y3], dim=0)
    t = torch.cat([t1, t2, t3], dim=0)

    terrain = get_terrain_features_torch(dem, x, y)
    z_norm = terrain[:, 0]
    slope_norm = terrain[:, 1]
    acc_w = terrain[:, 2]
    low_w = terrain[:, 3]
    ch_w = terrain[:, 6]
    ch_p = terrain[:, 7]

    rain_mmhr = rainfall_fn(x, y, t) * 1000.0 * 3600.0
    base = 0.005 + 0.014 * low_w + 0.014 * acc_w + 0.012 * ch_w + 0.010 * ch_p
    rain_term = 0.00155 * rain_mmhr * (0.45 + 0.20 * low_w + 0.20 * acc_w + 0.15 * ch_w)
    terrain_term = 0.006 * (1.0 - slope_norm) + 0.004 * (1.0 - z_norm)
    h_obs = torch.clamp(base + rain_term + terrain_term, 0.003, 3.0)
    return x, y, t, h_obs

def ic_loss(model, dem, mesh):
    x, y, t = sample_ic(N_IC, mesh)
    h_total, h_dyn, u, v, sea_base = evaluate_model_total(model, dem, x, y, t)
    return (h_dyn ** 2).mean() + (u ** 2).mean() + (v ** 2).mean()

def bc_loss(model, dem, mesh):
    bc = sample_bc(N_BC, mesh)
    loss = 0.0

    for side in ["west", "south"]:
        x, y, t = bc[side]
        h_total, _, u, v, sea_base = evaluate_model_total(model, dem, x, y, t)
        ow = sample_field_torch(dem["ocean_mask_tensor"], x, y).clamp(0, 1)
        loss += (((h_total - sea_base) ** 2) * ow).mean()
        if side == "west":
            loss += ((u ** 2) * (1.0 - ow)).mean()
        else:
            loss += ((v ** 2) * (1.0 - ow)).mean()

    x, y, t = bc["east"]
    _, _, u, _, _ = evaluate_model_total(model, dem, x, y, t)
    loss += (u ** 2).mean()

    x, y, t = bc["north"]
    _, _, _, v, _ = evaluate_model_total(model, dem, x, y, t)
    loss += (v ** 2).mean()
    return loss

def data_loss(model, rainfall_fn, dem, mesh):
    x, y, t, h_obs = sample_obs(N_OBS, rainfall_fn, dem, mesh)
    h_total, h_dyn, _, _, sea_base = evaluate_model_total(model, dem, x, y, t)
    return ((h_total - sea_base - h_obs) ** 2).mean()

def channel_guidance_loss(model, rainfall_fn, dem, mesh):
    x, y, t, _ = sample_channel_mesh(N_CH, mesh)
    h_total, h_dyn, _, _, sea_base = evaluate_model_total(model, dem, x, y, t)
    h_flood = h_total - sea_base
    rain_mmhr = rainfall_fn(x, y, t) * 1000.0 * 3600.0
    terrain = get_terrain_features_torch(dem, x, y)
    z_norm, slope_norm, acc_w, low_w, _, _, ch_w, ch_p = [terrain[:, i] for i in range(8)]
    target = (
        0.006 + 0.020 * ch_w + 0.018 * ch_p + 0.010 * acc_w + 0.006 * low_w +
        0.00125 * rain_mmhr * (0.50 + 0.25 * ch_w + 0.15 * ch_p + 0.10 * acc_w) +
        0.003 * (1.0 - slope_norm) + 0.002 * (1.0 - z_norm)
    )
    return ((h_flood - target.clamp(0.004, 2.0)) ** 2).mean()

def pluvial_spread_loss(model, rainfall_fn, dem, mesh):
    x, y, t, _ = sample_floodplain_mesh(N_PLUVIAL, mesh)
    h_total, h_dyn, _, _, sea_base = evaluate_model_total(model, dem, x, y, t)
    h_flood = h_total - sea_base
    rain_mmhr = rainfall_fn(x, y, t) * 1000.0 * 3600.0
    terrain = get_terrain_features_torch(dem, x, y)
    z_norm, slope_norm, acc_w, low_w, _, _, ch_w, ch_p = [terrain[:, i] for i in range(8)]
    target = (
        0.004 + 0.012 * low_w + 0.008 * acc_w + 0.010 * ch_p +
        0.00105 * rain_mmhr * (0.62 + 0.20 * low_w + 0.10 * ch_p + 0.08 * acc_w) +
        0.002 * (1.0 - slope_norm) + 0.002 * (1.0 - z_norm)
    )
    weight = torch.clamp(rain_mmhr / 80.0, 0.2, 1.0)
    return weighted_mean_torch((h_flood - target.clamp(0.003, 1.6)) ** 2, weight)

def terrain_alignment_loss(model, rainfall_fn, dem, mesh):
    x, y, t, _ = sample_channel_mesh(N_ALIGN, mesh)
    h_total, h_dyn, u, v, sea_base = evaluate_model_total(model, dem, x, y, t)
    qx = h_total * u
    qy = h_total * v
    qmag = torch.sqrt(qx * qx + qy * qy + 1e-8)

    dirx = sample_field_torch(dem["dirx_tensor"], x, y)
    diry = sample_field_torch(dem["diry_tensor"], x, y)
    terrain = get_terrain_features_torch(dem, x, y)
    acc_w, low_w, slope_norm, ch_w, ch_p = terrain[:, 2], terrain[:, 3], terrain[:, 1], terrain[:, 6], terrain[:, 7]
    rain_mmhr = rainfall_fn(x, y, t) * 1000.0 * 3600.0
    rain_w = torch.clamp(rain_mmhr / 120.0, 0.0, 1.0)
    dot = (qx / (qmag + 1e-6)) * dirx + (qy / (qmag + 1e-6)) * diry
    hydro = 0.35 * ch_w + 0.25 * ch_p + 0.25 * acc_w + 0.15 * low_w
    weight = hydro * (0.25 + 0.75 * rain_w) * torch.clamp(h_total / 0.20, 0.0, 1.0)
    return weighted_mean_torch((1.0 - dot) ** 2, weight + 1e-6)

def dry_suppression_loss(model, rainfall_fn, dem, mesh):
    x, y, t, _ = sample_dry_mesh(N_DRY, mesh)
    h_total, h_dyn, _, _, sea_base = evaluate_model_total(model, dem, x, y, t)
    h_flood = h_total - sea_base
    terrain = get_terrain_features_torch(dem, x, y)
    acc_w, low_w, slope_norm, ch_w = terrain[:, 2], terrain[:, 3], terrain[:, 1], terrain[:, 6]
    rain_mmhr = rainfall_fn(x, y, t) * 1000.0 * 3600.0
    rain_w = torch.clamp(rain_mmhr / 100.0, 0.0, 1.0)
    dry_weight = (1.0 - acc_w) * (1.0 - low_w) * (1.0 - ch_w) * (1.0 - rain_w)
    target = 0.001 + 0.002 * rain_w + 0.001 * (1.0 - slope_norm)
    return weighted_mean_torch(((h_flood - target).clamp(min=0.0)) ** 2, dry_weight + 1e-6)

def ocean_consistency_loss(model, rainfall_fn, dem, mesh):
    x, y, t, _ = sample_ocean_mesh(N_OCEAN, mesh)
    h_total, h_dyn, u, v, sea_base = evaluate_model_total(model, dem, x, y, t)
    ow = sample_field_torch(dem["ocean_mask_tensor"], x, y).clamp(0, 1)
    loss_h = (((h_total - sea_base) ** 2) * ow).mean()
    loss_uv = ((u * u + v * v) * ow).mean()
    return loss_h + 0.10 * loss_uv

def discharge_guidance_loss(model, rainfall_fn, dem, mesh):
    x, y, t, _ = sample_channel_mesh(N_QGUIDE, mesh)
    h_total, h_dyn, u, v, sea_base = evaluate_model_total(model, dem, x, y, t)
    qmag = h_total * torch.sqrt(u * u + v * v + 1e-8)
    terrain = get_terrain_features_torch(dem, x, y)
    acc_w, low_w, ch_w, ch_p = terrain[:, 2], terrain[:, 3], terrain[:, 6], terrain[:, 7]
    rain_mmhr = rainfall_fn(x, y, t) * 1000.0 * 3600.0
    target = (
        0.015 + 0.06 * ch_w + 0.05 * ch_p + 0.03 * acc_w +
        0.0022 * rain_mmhr * (0.35 + 0.35 * ch_w + 0.20 * ch_p + 0.10 * acc_w)
    )
    w = 0.20 + 0.40 * ch_w + 0.25 * ch_p + 0.15 * acc_w
    return weighted_mean_torch((qmag - target.clamp(0.01, 2.5)) ** 2, w)

