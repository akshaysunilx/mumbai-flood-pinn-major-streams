def make_single_panel_gif(frames_data, dem, out_path, title_prefix, kind="depth", gif_fps=GIF_FPS):
    os.makedirs(os.path.dirname(out_path) or ".", exist_ok=True)

    extent = get_plot_extent_km(dem)
    res = frames_data[0]["field"].shape[0]
    xkm = np.linspace(extent[0], extent[1], res)
