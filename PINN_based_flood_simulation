def make_field_tensor(arr, device=DEVICE):
    return torch.from_numpy(arr.astype(np.float32)[None, None, :, :]).to(device)

def make_multi_tensor(arr_chw, device=DEVICE):
    return torch.from_numpy(arr_chw.astype(np.float32)[None, :, :, :]).to(device)

def sample_multi_field_torch(field_4d, x, y, mode="bilinear"):
    _, C, H, W = field_4d.shape

    xp = x * (W - 1)
    yp = y * (H - 1)

    x0 = torch.floor(xp).long().clamp(0, W - 2)
    y0 = torch.floor(yp).long().clamp(0, H - 2)
    x1 = (x0 + 1).clamp(0, W - 1)
    y1 = (y0 + 1).clamp(0, H - 1)

    wx1 = (xp - x0.float()).clamp(0.0, 1.0)
    wy1 = (yp - y0.float()).clamp(0.0, 1.0)
    wx0 = 1.0 - wx1
    wy0 = 1.0 - wy1

    field_flat = field_4d[0].reshape(C, -1)

    idx_00 = y0 * W + x0
    idx_01 = y0 * W + x1
    idx_10 = y1 * W + x0
    idx_11 = y1 * W + x1

    v00 = field_flat[:, idx_00]
    v01 = field_flat[:, idx_01]
    v10 = field_flat[:, idx_10]
    v11 = field_flat[:, idx_11]

    out = (
        v00 * (wy0 * wx0) +
        v01 * (wy0 * wx1) +
        v10 * (wy1 * wx0) +
        v11 * (wy1 * wx1)
    )
    return out.T

def sample_field_torch(field_4d, x, y, mode="bilinear"):
    return sample_multi_field_torch(field_4d, x, y, mode=mode)[:, 0]

def get_terrain_features_torch(dem, x, y):
    return sample_multi_field_torch(dem["terrain_tensor"], x, y, mode="bilinear")

