def save_geotiff(array_southup, dem, save_path, nodata=-9999.0, dtype="float32"):
    import rasterio

    arr = np.flipud(array_southup.astype(np.float32))
    arr_out = np.where(np.isfinite(arr), arr, nodata).astype(np.float32)
    with rasterio.open(
        save_path,
        "w",
        driver="GTiff",
        height=arr_out.shape[0],
        width=arr_out.shape[1],
        count=1,
        dtype=dtype,
        crs=dem["crs"],
        transform=dem["transform"],
        nodata=nodata,
        compress="lzw",
    ) as dst:
        dst.write(arr_out, 1)
    print(f"[SAVED] {save_path}")

def save_coarse_numeric_csv(peak_depth, peak_speed, peak_q, arrival_min, dem, save_path, res=NUMERIC_CSV_RES):
    extent = get_plot_extent_km(dem)
    xkm = np.linspace(extent[0], extent[1], res)
    ykm = np.linspace(extent[2], extent[3], res)
    ocean = get_ocean_grid(dem, res)
    valid = get_valid_grid(dem, res)

    with open(save_path, "w", newline="") as f:
        writer = csv.writer(f)
        writer.writerow(["x_km", "y_km", "peak_land_depth_m", "peak_speed_mps", "peak_unit_discharge_m2ps", "arrival_min", "is_ocean", "is_valid"])
        for i, yv in enumerate(ykm):
            for j, xv in enumerate(xkm):
                d = peak_depth[i, j]
                s = peak_speed[i, j]
                q = peak_q[i, j]
                a = arrival_min[i, j]
                writer.writerow([
                    float(xv),
                    float(yv),
                    "" if not np.isfinite(d) else float(d),
                    "" if not np.isfinite(s) else float(s),
                    "" if not np.isfinite(q) else float(q),
                    "" if not np.isfinite(a) else float(a),
                    int(ocean[i, j] >= 0.5),
                    int(valid[i, j] >= 0.5),
                ])
    print(f"[SAVED] {save_path}")

