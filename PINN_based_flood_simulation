    valid_res = get_valid_grid(dem, grid_res)
    ocean_res = get_ocean_grid(dem, grid_res)
    stream_res = get_stream_overlay(dem, grid_res)
    watershed_res = get_watershed_boundary_overlay(dem, grid_res)
    dirx_res, diry_res = get_dir_overlay(dem, grid_res)
    contour_lvls = compute_contour_levels(dem_res, n_levels=N_CONTOURS)

    rain_fields = []
    flood_fields = []
    u_fields = []
    v_fields = []
    speed_fields = []
    q_fields = []

    rain_max = 20.0
    depth_max = 0.5
    speed_max = 0.5
    q_max = 0.1

    for tn in tvals:
        _, _, R = rainfall_grid(rainfall_fn, tn, grid_res)
        _, _, _, H_fl, U, V, _, _, _ = predict_field(model, dem, tn, grid_res)
        S = np.sqrt(U ** 2 + V ** 2)
        Q = H_fl * S
        Q[~np.isfinite(H_fl)] = np.nan

        rain_fields.append(R)
        flood_fields.append(H_fl)
        u_fields.append(U)
        v_fields.append(V)
        speed_fields.append(S)
        q_fields.append(Q)

        if np.isfinite(R).any():
            rain_max = max(rain_max, safe_percentile(R, 99, 20.0))
        if np.isfinite(H_fl).any():
            depth_max = max(depth_max, safe_percentile(H_fl, 99, 0.5))
        if np.isfinite(S).any():
            speed_max = max(speed_max, safe_percentile(S, 99, 0.5))
        if np.isfinite(Q).any():
            q_max = max(q_max, safe_percentile(Q, 99, 0.1))

    print(f"[GIF] Rain max={rain_max:.1f} mm/hr | Depth max={depth_max:.2f} m | Speed max={speed_max:.2f} m/s | Q max={q_max:.2f} m²/s")

    depth_stk = np.stack([np.where(np.isfinite(H), H, -np.inf) for H in flood_fields], axis=0)
    peak_H_land = np.max(depth_stk, axis=0)
    peak_H_land[peak_H_land == -np.inf] = np.nan
    peak_H_land[ocean_res >= 0.5] = np.nan
    peak_speed_land = peak_speed_from_fields(flood_fields, u_fields, v_fields, ocean_res)
    peak_q_land = peak_discharge_from_fields(flood_fields, u_fields, v_fields, ocean_res)
    arrival_min = arrival_time_from_fields(flood_fields, tvals, ocean_res, threshold=ARRIVAL_DEPTH_THRESHOLD)

    frames = []
    rain_only_frames = []
    depth_only_frames = []
    speed_only_frames = []
    discharge_only_frames = []

    panel_w, panel_h = get_panel_figsize(dem, base_h=5.0)
    fig_w = 3.0 * panel_w + 2.8
    fig_h = panel_h + 0.9

    for i, tn in enumerate(tvals):
        R = rain_fields[i]
        H_land = flood_fields[i]
        U = u_fields[i]
        V = v_fields[i]
        S = speed_fields[i]
        Q = q_fields[i]

        H_plot = H_land.copy()
        H_plot[H_plot < WET_DEPTH_THRESHOLD] = np.nan
        Ub, Vb = blend_flow_for_display(U, V, H_plot, dirx_res, diry_res)
        sim_min = (tn * T_END_SECONDS) / 60.0

        fig, (ax1, ax2, ax3) = plt.subplots(1, 3, figsize=(fig_w, fig_h), dpi=120)

        add_context_layers(ax1, dem_bg, dem_res, valid_res, ocean_res, stream_res, watershed_res, extent, contour_lvls, xkm, ykm)
        im1 = ax1.imshow(R, extent=extent, origin="lower", cmap="Blues", vmin=0, vmax=rain_max, alpha=0.82 if dem_bg is not None else 1.0, aspect="equal")
        ax1.set_title(f"Spatial Rainfall + D8 Watershed Streams\nTime = {sim_min:.1f} min")
        ax1.set_xlabel("Easting (km)")
        ax1.set_ylabel("Northing (km)")
        fig.colorbar(im1, ax=ax1, fraction=0.046, pad=0.03).set_label("Rainfall (mm/hr)")

        add_context_layers(ax2, dem_bg, dem_res, valid_res, ocean_res, stream_res, watershed_res, extent, contour_lvls, xkm, ykm)
        im2 = ax2.imshow(H_plot, extent=extent, origin="lower", cmap="turbo", vmin=0, vmax=depth_max, alpha=0.86, aspect="equal")
        add_flow_overlay(ax2, xkm, ykm, Ub, Vb, H_plot)
        ax2.set_title(f"Land Flood Depth + D8 Watershed Streams\nTime = {sim_min:.1f} min")
        ax2.set_xlabel("Easting (km)")
        ax2.set_ylabel("Northing (km)")
        fig.colorbar(im2, ax=ax2, fraction=0.046, pad=0.03).set_label("Land inundation depth (m)")

        add_context_layers(ax3, dem_bg, dem_res, valid_res, ocean_res, stream_res, watershed_res, extent, contour_lvls, xkm, ykm)
        q_plot = Q.copy()
        q_plot[H_plot <= WET_DEPTH_THRESHOLD] = np.nan
        im3 = ax3.imshow(q_plot, extent=extent, origin="lower", cmap="inferno", vmin=0, vmax=q_max, alpha=0.84, aspect="equal")
        add_flow_overlay(ax3, xkm, ykm, Ub, Vb, H_plot)
        ax3.set_title(f"Discharge Intensity + D8 Watershed Streams\nTime = {sim_min:.1f} min")
        ax3.set_xlabel("Easting (km)")
        ax3.set_ylabel("Northing (km)")
        fig.colorbar(im3, ax=ax3, fraction=0.046, pad=0.03).set_label("Unit discharge proxy (m²/s)")

        fig.suptitle(f"Mumbai structured-grid hydraulic PINN | Frame {i + 1}/{gif_frames}", fontsize=14, fontweight="bold")
        fig.subplots_adjust(left=0.045, right=0.985, bottom=0.10, top=0.88, wspace=0.16)

        buf = io.BytesIO()
        fig.savefig(buf, format="png", dpi=120)
        plt.close(fig)
        buf.seek(0)
        frames.append(Image.open(buf).convert("P", palette=Image.ADAPTIVE).copy())

        rain_only_frames.append({
            "field": R.copy(),
            "t_norm": float(tn),
        })
        depth_only_frames.append({
            "field": H_plot.copy(),
            "t_norm": float(tn),
            "depth_for_flow": H_plot.copy(),
            "Ub": Ub.copy(),
            "Vb": Vb.copy(),
        })
        speed_plot = S.copy()
        speed_plot[~np.isfinite(H_plot)] = np.nan
        speed_plot[H_plot <= WET_DEPTH_THRESHOLD] = np.nan
        speed_only_frames.append({
            "field": speed_plot,
            "t_norm": float(tn),
            "depth_for_flow": H_plot.copy(),
            "Ub": Ub.copy(),
            "Vb": Vb.copy(),
        })
        discharge_only_frames.append({
            "field": q_plot.copy(),
            "t_norm": float(tn),
            "depth_for_flow": H_plot.copy(),
            "Ub": Ub.copy(),
            "Vb": Vb.copy(),
        })

    frames[0].save(out_path, save_all=True, append_images=frames[1:], duration=int(1000 / gif_fps), loop=0, optimize=True)
    print(f"[SAVED] {out_path}")

    base_dir = os.path.dirname(out_path)
    base_name = os.path.splitext(os.path.basename(out_path))[0]
    rain_gif_path = os.path.join(base_dir, f"{base_name}_rainfall_only.gif")
    depth_gif_path = os.path.join(base_dir, f"{base_name}_inundation_only.gif")
    speed_gif_path = os.path.join(base_dir, f"{base_name}_flow_speed_only.gif")
    discharge_gif_path = os.path.join(base_dir, f"{base_name}_discharge_only.gif")

    make_single_panel_gif(rain_only_frames, dem, rain_gif_path, "Spatial Rainfall", kind="rain", gif_fps=gif_fps)
    make_single_panel_gif(depth_only_frames, dem, depth_gif_path, "Land Inundation + Flow", kind="depth", gif_fps=gif_fps)
    make_single_panel_gif(speed_only_frames, dem, speed_gif_path, "Flow Speed + Direction", kind="speed", gif_fps=gif_fps)
    make_single_panel_gif(discharge_only_frames, dem, discharge_gif_path, "Discharge Intensity + Streamlines", kind="discharge", gif_fps=gif_fps)

    print(f"[NATIVE] Computing native peak fields over {NATIVE_ANALYSIS_FRAMES} time slices...")
    tvals_native = np.linspace(0.0, 1.0, NATIVE_ANALYSIS_FRAMES)
    peak_native_depth = np.full((dem["h"], dem["w"]), -np.inf, np.float32)
    peak_native_speed = np.full((dem["h"], dem["w"]), -np.inf, np.float32)
    peak_native_q = np.full((dem["h"], dem["w"]), -np.inf, np.float32)
    arrival_native = np.full((dem["h"], dem["w"]), np.nan, np.float32)

    for tn in tvals_native:
        _, H_ln, Un, Vn = predict_native_field(model, dem, tn)
        Sn = np.sqrt(Un ** 2 + Vn ** 2)
        Qn = H_ln * Sn
        peak_native_depth = np.maximum(peak_native_depth, np.where(np.isfinite(H_ln), H_ln, -np.inf))
        peak_native_speed = np.maximum(peak_native_speed, np.where(np.isfinite(Sn), Sn, -np.inf))
        peak_native_q = np.maximum(peak_native_q, np.where(np.isfinite(Qn), Qn, -np.inf))
        hit = np.isnan(arrival_native) & np.isfinite(H_ln) & (H_ln >= ARRIVAL_DEPTH_THRESHOLD)
        arrival_native[hit] = tn * T_END_SECONDS / 60.0

    peak_native_depth[peak_native_depth == -np.inf] = np.nan
    peak_native_speed[peak_native_speed == -np.inf] = np.nan
    peak_native_q[peak_native_q == -np.inf] = np.nan

    peak_native_depth[dem["ocean_mask"]] = np.nan
    peak_native_speed[dem["ocean_mask"]] = np.nan
    peak_native_q[dem["ocean_mask"]] = np.nan
    arrival_native[dem["ocean_mask"]] = np.nan

    peak_native_depth[~dem["valid_mask"]] = np.nan
    peak_native_speed[~dem["valid_mask"]] = np.nan
    peak_native_q[~dem["valid_mask"]] = np.nan
    arrival_native[~dem["valid_mask"]] = np.nan

    return {
        "peak_H_land_plot": peak_H_land,
        "peak_speed_land_plot": peak_speed_land,
        "peak_q_land_plot": peak_q_land,
        "arrival_min_plot": arrival_min,
        "peak_H_land_native": peak_native_depth,
        "peak_speed_land_native": peak_native_speed,
        "peak_q_land_native": peak_native_q,
        "arrival_min_native": arrival_native,
        "rain_gif_path": rain_gif_path,
        "depth_gif_path": depth_gif_path,
        "speed_gif_path": speed_gif_path,
        "discharge_gif_path": discharge_gif_path,
        "peak_rain_mmhr": rain_max,
        "peak_depth_m": safe_percentile(peak_native_depth, 99, 0.0),
        "rain_cube": np.stack(rain_fields, axis=0).astype(np.float32),
        "depth_cube": np.stack(flood_fields, axis=0).astype(np.float32),
        "speed_cube": np.stack(speed_fields, axis=0).astype(np.float32),
        "q_cube": np.stack(q_fields, axis=0).astype(np.float32),
        "time_values": tvals,
    }

# ============================================================
# RUN ONE CASE
# ============================================================
def run_case(case, dem, mesh):
    case_name = case["name"]
    slug = slugify(case_name)
    case_dir = os.path.join(OUT_DIR, slug)
    os.makedirs(case_dir, exist_ok=True)

    print("\n" + "=" * 76)
    print(f"[CASE] {case_name}")
    print("=" * 76)

    rainfall_fn = build_rainfall_fn(case)
    model = FloodPINN(hidden=HIDDEN, layers=LAYERS, fourier=FOURIER, terrain_features=TERRAIN_FEATURES).to(DEVICE)
    history = train_model(model, dem, mesh, rainfall_fn, epochs=EPOCHS_PER_CASE)

    model_path = os.path.join(case_dir, f"{slug}_model.pt")
    torch.save(model.state_dict(), model_path)
    print(f"[SAVED] {model_path}")

    loss_path = os.path.join(case_dir, f"{slug}_loss.png")
    plot_loss(history, loss_path, f"{case_name} - training loss")

    gif_path = os.path.join(case_dir, f"{slug}_hydraulic_response.gif")
    gif_info = make_hydraulic_gif(model=model, dem=dem, rainfall_fn=rainfall_fn, out_path=gif_path, grid_res=GRID_RES, gif_frames=GIF_FRAMES, gif_fps=GIF_FPS)

    peak_depth_map_path = os.path.join(case_dir, f"{slug}_peak_land_inundation_depth_map.png")
    peak_speed_map_path = os.path.join(case_dir, f"{slug}_peak_land_flood_speed_map.png")
    peak_q_map_path = os.path.join(case_dir, f"{slug}_peak_land_discharge_map.png")
    arrival_map_path = os.path.join(case_dir, f"{slug}_arrival_time_map.png")

    plot_peak_depth_map(gif_info["peak_H_land_plot"], dem, peak_depth_map_path, f"{case_name} - Peak Land Inundation Depth")
    plot_peak_speed_map(gif_info["peak_speed_land_plot"], dem, peak_speed_map_path, f"{case_name} - Peak Land Flood Speed")
    plot_peak_discharge_map(gif_info["peak_q_land_plot"], dem, peak_q_map_path, f"{case_name} - Peak Unit Discharge")
    plot_arrival_time_map(gif_info["arrival_min_plot"], dem, arrival_map_path, f"{case_name} - Arrival Time")

    save_numeric_outputs(
        case_dir=case_dir,
        slug=slug,
        dem=dem,
        peak_H_land=gif_info["peak_H_land_native"],
        peak_speed_land=gif_info["peak_speed_land_native"],
        peak_q_land=gif_info["peak_q_land_native"],
        arrival_min=gif_info["arrival_min_native"],
        rain_cube=gif_info["rain_cube"],
        depth_cube=gif_info["depth_cube"],
        speed_cube=gif_info["speed_cube"],
        q_cube=gif_info["q_cube"],
        time_values=gif_info["time_values"],
    )

    summary = {
        "case": case_name,
        "case_dir": case_dir,
        "model_path": model_path,
        "loss_plot": loss_path,
        "gif_path": gif_path,
        "rain_gif_path": gif_info["rain_gif_path"],
        "depth_gif_path": gif_info["depth_gif_path"],
        "speed_gif_path": gif_info["speed_gif_path"],
        "discharge_gif_path": gif_info["discharge_gif_path"],
        "peak_depth_map_path": peak_depth_map_path,
        "peak_speed_map_path": peak_speed_map_path,
        "peak_q_map_path": peak_q_map_path,
        "arrival_map_path": arrival_map_path,
        "peak_rain_mmhr": gif_info["peak_rain_mmhr"],
        "peak_depth_m": gif_info["peak_depth_m"],
    }

    del model
    gc.collect()
    if torch.cuda.is_available():
        torch.cuda.empty_cache()
    return summary

# ============================================================
# MAIN
# ============================================================
def main():
    dem = load_dem(DEM_PATH)
    mesh = build_hydraulic_mesh(dem, mesh_m=HYDRAULIC_MESH_M)

    context_map_path = os.path.join(OUT_DIR, "mumbai_context_hydraulic_mesh.png")
    plot_hydraulic_context(dem, mesh, context_map_path, res=GRID_RES)

    all_summaries = []
    for case in SCENARIOS:
        all_summaries.append(run_case(case, dem, mesh))

    summary_plot_path = os.path.join(OUT_DIR, "scenario_comparison_hydraulic_mesh.png")
    plot_summary_bar(all_summaries, summary_plot_path)

    print("\n" + "=" * 76)
    print("[DONE] Outputs created:")
    print("=" * 76)
    print(f"\nContext map: {context_map_path}")
    for s in all_summaries:
        print(f"\nCase: {s['case']}")
        print(f"  Model            : {s['model_path']}")
        print(f"  Loss             : {s['loss_plot']}")
        print(f"  Combined GIF     : {s['gif_path']}")
        print(f"  Rain GIF         : {s['rain_gif_path']}")
        print(f"  Inundation GIF   : {s['depth_gif_path']}")
        print(f"  Flow speed GIF   : {s['speed_gif_path']}")
        print(f"  Discharge GIF    : {s['discharge_gif_path']}")
        print(f"  Peak depth map   : {s['peak_depth_map_path']}")
        print(f"  Peak speed map   : {s['peak_speed_map_path']}")
        print(f"  Peak discharge   : {s['peak_q_map_path']}")
        print(f"  Arrival time map : {s['arrival_map_path']}")
        print(f"  Peak rain        : {s['peak_rain_mmhr']:.1f} mm/hr")
        print(f"  Peak depth       : {s['peak_depth_m']:.2f} m")
        print(f"  Numeric files    : saved in {s['case_dir']}")
    print(f"\nScenario comparison plot: {summary_plot_path}")

if __name__ == "__main__":
    main()
